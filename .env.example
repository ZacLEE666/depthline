# Optional. Depthline checks PATH and common macOS app locations automatically.
# Set an absolute path only when Codex is installed somewhere else.
DEPTHLINE_CODEX_BIN=

# Optional. Run without reading Codex and use safe sample data.
DEPTHLINE_DEMO=0

# Optional. Defaults to ~/.depthline
DEPTHLINE_DATA_DIR=

# Optional. Defaults to 4545. Server always binds to 127.0.0.1.
DEPTHLINE_PORT=4545
